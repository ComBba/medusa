{
  "name": "root",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/medusa",
      "packages/medusa-test-utils",
      "packages/modules/*",
      "packages/modules/providers/*",
      "packages/core/*",
      "packages/framework/*",
      "packages/cli/*",
      "packages/cli/oas/*",
      "packages/*",
      "packages/admin/*",
      "packages/design-system/*",
      "packages/generated/*",
      "integration-tests/**/*"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@eslint/js": "^9.17.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3",
    "turbo": "^2.3.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "yarn run lint",
    "*.{md,yaml,yml}": "prettier --write"
  },
  "scripts": {
    "build": "yarn workspaces foreach --all run build",
    "dev": "yarn workspaces foreach --all run dev",
    "kbeauty:dev": "concurrently \"yarn kbeauty:docker\" \"yarn kbeauty:backend\" \"yarn kbeauty:admin\"",
    "kbeauty:docker": "docker-compose up -d postgres redis adminer minio",
    "kbeauty:backend": "yarn workspace @medusajs/medusa dev --port 10000",
    "kbeauty:admin": "yarn workspace @medusajs/admin dev --port 10001",
    "kbeauty:build": "yarn build",
    "kbeauty:start": "yarn workspace @medusajs/medusa start --port 10000",
    "kbeauty:docker:up": "docker-compose up -d",
    "kbeauty:docker:down": "docker-compose down",
    "kbeauty:docker:logs": "docker-compose logs -f",
    "kbeauty:db:migrate": "yarn workspace @medusajs/medusa migrate",
    "kbeauty:db:seed": "yarn workspace @medusajs/medusa seed",
    "kbeauty:user:create": "yarn workspace @medusajs/medusa user --email admin@kbeauty.market --password admin123",
    "test": "jest --runInBand -- --testTimeout=30000"
  },
  "dependencies": {
    "@changesets/changelog-github": "^0.4.8",
    "@changesets/cli": "^2.26.0",
    "global": "^4.4.0",
    "import-from": "^3.0.0"
  },
  "packageManager": "yarn@3.2.1",
  "resolutions": {
    "@redocly/cli/react": "^17.0.1",
    "@redocly/cli/react-dom": "^17.0.1",
    "pg": "8.11.3",
    "@changesets/assemble-release-plan@^6.0.0": "patch:@changesets/assemble-release-plan@npm:^6.0.0#.yarn/patches/changesets.patch"
  }
}
