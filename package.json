{
  "name": "root",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/medusa",
      "packages/medusa-test-utils",
      "packages/modules/*",
      "packages/modules/providers/*",
      "packages/core/*",
      "packages/framework/*",
      "packages/cli/*",
      "packages/cli/oas/*",
      "packages/*",
      "packages/admin/*",
      "packages/design-system/*",
      "packages/generated/*",
      "integration-tests/**/*"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@eslint/js": "^9.17.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "yarn run lint",
    "*.{md,yaml,yml}": "prettier --write"
  },
      "scripts": {
    "build": "yarn workspaces foreach --all run build",
    "dev": "yarn workspaces foreach --all run dev",
    
    "kbeauty:quick-start": "./scripts/quick-start.sh",
    "kbeauty:manage": "./scripts/kbeauty-manager.sh",
    "kbeauty:db": "./scripts/kbeauty-db.sh",
    
    "kbeauty:start": "./scripts/kbeauty-manager.sh start all",
    "kbeauty:stop": "./scripts/kbeauty-manager.sh stop all",
    "kbeauty:restart": "./scripts/kbeauty-manager.sh restart all",
    "kbeauty:status": "./scripts/kbeauty-manager.sh status",
    "kbeauty:logs": "./scripts/kbeauty-manager.sh logs",
    "kbeauty:health": "./scripts/kbeauty-manager.sh health",
    "kbeauty:ports": "./scripts/kbeauty-manager.sh ports",
    "kbeauty:reset": "./scripts/kbeauty-manager.sh reset",
    
    "kbeauty:start-backend": "./scripts/kbeauty-manager.sh start backend",
    "kbeauty:start-frontend": "./scripts/kbeauty-manager.sh start storefront",
    "kbeauty:start-docker": "./scripts/kbeauty-manager.sh start docker",
    
    "kbeauty:db-migrate": "./scripts/kbeauty-db.sh migrate",
    "kbeauty:db-seed": "./scripts/kbeauty-db.sh seed",
    "kbeauty:db-backup": "./scripts/kbeauty-db.sh backup",
    "kbeauty:db-connect": "./scripts/kbeauty-db.sh connect",
    "kbeauty:create-admin": "./scripts/kbeauty-db.sh create-admin",
    
    "test": "jest --runInBand -- --testTimeout=30000"
  },
  "dependencies": {
    "@changesets/changelog-github": "^0.4.8",
    "@changesets/cli": "^2.26.0",
    "global": "^4.4.0",
    "import-from": "^3.0.0"
  },
  "packageManager": "yarn@3.2.1",
  "resolutions": {
    "@redocly/cli/react": "^17.0.1",
    "@redocly/cli/react-dom": "^17.0.1",
    "pg": "8.11.3",
    "@changesets/assemble-release-plan@^6.0.0": "patch:@changesets/assemble-release-plan@npm:^6.0.0#.yarn/patches/changesets.patch"
  }
}
