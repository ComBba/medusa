# Database Configuration
DATABASE_URL=postgres://medusa:medusa@localhost:10002/kbeauty_market

# Redis Configuration
REDIS_URL=redis://localhost:10003

# Server Configuration
PORT=10000
HOST=0.0.0.0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key
COOKIE_SECRET=your-super-secret-cookie-key

# Admin Configuration
ADMIN_PATH=/app
ADMIN_CORS=https://admin.kbeauty.market,http://admin.kbeauty.market,http://localhost:10000

# Store Configuration
STORE_CORS=https://kbeauty.market,http://kbeauty.market,http://localhost:10004

# Auth Configuration
AUTH_CORS=https://admin.kbeauty.market,http://admin.kbeauty.market,https://kbeauty.market,http://kbeauty.market,http://localhost:10000

# Backend URL
MEDUSA_BACKEND_URL=https://api.kbeauty.market

# MinIO/S3 Configuration
MINIO_ENDPOINT=localhost:10009
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=kbeauty-uploads

# Email Configuration (Optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Payment Configuration
# STRIPE_API_KEY=sk_test_...
# PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Amazon SP-API Configuration (샌드박스)
# LWA (Login with Amazon) 설정
AMAZON_LWA_CLIENT_ID=your-lwa-client-id
AMAZON_LWA_CLIENT_SECRET=your-lwa-client-secret
AMAZON_LWA_REFRESH_TOKEN=your-refresh-token

# AWS 자격 증명 (SP-API 접근용)
AMAZON_AWS_ACCESS_KEY_ID=your-aws-access-key-id
AMAZON_AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AMAZON_AWS_REGION=us-east-1

# Amazon SP-API 설정
AMAZON_SP_API_REGION=na
AMAZON_SP_API_SANDBOX=true
AMAZON_SELLER_ID=your-seller-id

# 지원할 마켓플레이스 (쉼표로 구분)
AMAZON_MARKETPLACE_IDS=ATVPDKIKX0DER,A2EUQ1WTGCTBG2,A1AM78C64UM0Y8,A39IBJ37TRP1C6,A1RKKUPIHCS9HS,APJ6JRA9NG5V4

# 마켓플레이스별 설정 (JSON 형태)
AMAZON_MARKETPLACE_CONFIG={"ATVPDKIKX0DER":{"name":"Amazon.com","country":"US","currency":"USD","timezone":"America/New_York"},"A2EUQ1WTGCTBG2":{"name":"Amazon.ca","country":"CA","currency":"CAD","timezone":"America/Toronto"},"A1AM78C64UM0Y8":{"name":"Amazon.com.mx","country":"MX","currency":"MXN","timezone":"America/Mexico_City"},"A39IBJ37TRP1C6":{"name":"Amazon.com.au","country":"AU","currency":"AUD","timezone":"Australia/Sydney"},"A1RKKUPIHCS9HS":{"name":"Amazon.es","country":"ES","currency":"EUR","timezone":"Europe/Madrid"},"APJ6JRA9NG5V4":{"name":"Amazon.co.jp","country":"JP","currency":"JPY","timezone":"Asia/Tokyo"}}

# Amazon 통합 모듈 설정
AMAZON_INTEGRATION_ENABLED=true
AMAZON_AUTO_SYNC_ENABLED=true
AMAZON_SYNC_INTERVAL_MINUTES=30
AMAZON_MAX_RETRY_ATTEMPTS=3
AMAZON_RATE_LIMIT_PER_SECOND=10

# External APIs (Legacy)
# AMAZON_API_KEY=your-amazon-api-key
# AMAZON_SECRET_KEY=your-amazon-secret-key

# Environment
NODE_ENV=development 